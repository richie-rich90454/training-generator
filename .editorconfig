# EditorConfig helps maintain consistent formatting across editors and IDEs.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# JSON, YAML, and Markdown use 2-space indentation (package.json convention)
[*.{json,yml,yaml,md,markdown}]
indent_size = 2

# Makefiles must use tabs
[Makefile]
indent_style = tab

# Web manifest and lockfiles keep 2-space indent
[package-lock.json]
indent_size = 2
