{
  "name": "training-generator",
  "version": "2.0.0",
  "type": "module",
  "main": "src/main.ts",
  "types": "src/types/interfaces.ts",
  "scripts": {
    "start": "cross-env NODE_ENV=production node --import tsx/esm node_modules/electron/cli.js .",
    "dev": "vite & cross-env NODE_ENV=development node --import tsx/esm node_modules/electron/cli.js .",
    "build": "vite build",
    "preview": "vite preview",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "ollama",
    "ai",
    "training",
    "llm",
    "fine-tuning"
  ],
  "author": "richie-rich90454",
  "license": "MIT",
  "description": "Desktop application to convert documents into AI training data using Ollama",
  "build": {
    "appId": "com.training.generator",
    "productName": "Training Generator",
    "copyright": "Copyright © 2026 richie-rich90454",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "src/**/*",
      "tsconfig.json",
      "tsconfig.json",
      "native-splash/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/.{git,hg,svn}",
      "!**/{.DS_Store,.git,.hg,.svn,__pycache__,thumbs.db,.gitignore,.idea,.vscode}",
      "!**/*.{iml,o,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!**/._*",
      "!**/*.log",
      "!**/test*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "native-splash",
        "to": "native-splash"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "native-splash/**",
      "**/pdf-parse/**/*",
      "**/officeparser/**/*",
      "**/mammoth/**/*",
      "**/rtf-parser-fixes/**/*"
    ],
    "win": {
      "icon": "assets/favicon.ico",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        },
        {
          "target": "portable",
          "arch": "x64"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Training Generator",
      "installerIcon": "assets/favicon.ico",
      "uninstallerIcon": "assets/favicon.ico",
      "installerHeaderIcon": "assets/favicon.ico",
      "license": "LICENSE"
    },
    "mac": {
      "icon": "assets/favicon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ]
    },
    "linux": {
      "icon": "assets/favicon.png",
      "maintainer": "richie-rich90454 <noreply@github.com>",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "richie-rich90454",
        "repo": "training-generator",
        "private": false
      }
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "glob": "^13.0.6",
    "terser": "^5.48.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-copy": "^0.1.6",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "html-to-text": "^10.0.0",
    "mammoth": "^1.12.0",
    "officeparser": "^7.2.1",
    "pdf-parse": "^2.4.5",
    "rtf-parser-fixes": "^1.3.4"
  }
}
