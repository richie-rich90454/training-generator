{
  "name": "training-generator",
  "version": "2.0.1",
  "type": "module",
  "main": "src/main.ts",
  "types": "src/types/interfaces.ts",
  "sideEffects": [
    "**/*.css",
    "**/*.module.css"
  ],
  "scripts": {
    "prestart": "npm run build",
    "start": "cross-env NODE_ENV=production node --import tsx/esm node_modules/electron/cli.js .",
    "dev": "node scripts/dev.mjs",
    "build": "npm run build:main && vite build",
    "build:main": "node scripts/build-main.mjs",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win --publish=never",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/index.ts",
    "postinstall": "node scripts/postinstall.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "electron",
    "ollama",
    "ai",
    "training",
    "llm",
    "fine-tuning",
    "solidjs"
  ],
  "author": "richie-rich90454",
  "license": "MIT",
  "description": "Desktop application to convert documents into AI training data using Ollama (SolidJS UI)",
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.training.generator",
    "productName": "Training Generator",
    "copyright": "Copyright © 2026 richie-rich90454",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "dist-main/**/*",
      "node_modules/**/*",
      "src/prompts/**/*",
      "tsconfig.json",
      "package.json",
      "!src/**/*.ts",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/.{git,hg,svn}",
      "!**/{.DS_Store,.git,.hg,.svn,__pycache__,thumbs.db,.gitignore,.idea,.vscode}",
      "!**/*.{iml,o,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!**/._*",
      "!**/*.log",
      "!**/test*"
    ],
    "extraMetadata": {
      "main": "dist-main/main.js"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "docs",
        "to": "docs"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**",
      "**/pdf-parse/**/*",
      "**/officeparser/**/*",
      "**/mammoth/**/*",
      "**/rtf-parser-fixes/**/*"
    ],
    "win": {
      "icon": "assets/favicon.ico",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        },
        {
          "target": "portable",
          "arch": "x64"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Training Generator",
      "installerIcon": "assets/favicon.ico",
      "uninstallerIcon": "assets/favicon.ico",
      "installerHeaderIcon": "assets/favicon.ico",
      "license": "LICENSE"
    },
    "mac": {
      "icon": "assets/favicon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ]
    },
    "linux": {
      "icon": "assets/favicon.png",
      "maintainer": "richie-rich90454 <noreply@github.com>",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "richie-rich90454",
        "repo": "training-generator",
        "private": false
      }
    ]
  },
  "devDependencies": {
    "@solidjs/router": "^0.16.2",
    "@solidjs/testing-library": "^0.8.10",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "glob": "^13.0.6",
    "happy-dom": "^20.10.6",
    "solid-js": "^1.9.14",
    "terser": "^5.49.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-copy": "^0.1.6",
    "vite-plugin-solid": "^2.11.13",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "html-to-text": "^10.0.0",
    "mammoth": "^1.12.0",
    "officeparser": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "rtf-parser-fixes": "^1.3.4"
  }
}
