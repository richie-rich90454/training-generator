{
    "compilerOptions":{
        "target":"ES2020",
        "module":"ESNext",
        "moduleResolution":"bundler",
        "strict":true,
        "esModuleInterop":true,
        "skipLibCheck":true,
        "forceConsistentCasingInFileNames":true,
        "declaration":true,
        "outDir":"./dist-ts",
        "rootDir":".",
        "resolveJsonModule":true,
        "isolatedModules":true,
        "noEmit":true,
        "lib":["ES2020","DOM","DOM.Iterable"]
    },
    "include":[
        "src/**/*.ts",
        "tests/**/*.ts",
        "jest.config.ts",
        "vite.config.ts",
        "test-app.ts",
        "test-complete.ts",
        "test-ollama.ts",
        "test_language_prompts.ts"
    ],
    "exclude":[
        "node_modules",
        "dist",
        "dist-ts",
        "release"
    ]
}
